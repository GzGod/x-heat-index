{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/chenboyu/Documents/.claude/hooks/pre-edit-constraints.py",
            "timeout": 5,
            "statusMessage": "Loading proof constraints..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chenboyu/Documents/.claude/hooks/pre-commit-codex-review.sh",
            "timeout": 120,
            "statusMessage": "Running codex review gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/chenboyu/Documents/.claude/hooks/proof-circuit-verify.py",
            "timeout": 10,
            "statusMessage": "Running proof circuit verification..."
          }
        ]
      }
    ]
  }
}
